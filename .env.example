# --- Okta OIDC (SSO) ---
# Issuer is already provisioned for WWT SSO.
OKTA_ISSUER=https://sso.wwt.com/oauth2/default
OKTA_CLIENT_ID=
OKTA_CLIENT_SECRET=

# --- NextAuth ---
# Generate with: openssl rand -base64 32
AUTH_SECRET=
# Set to the deployed URL in production (e.g. https://d2os-care.wwt.com)
AUTH_URL=http://localhost:3000
# Allow the app to trust the host header behind a proxy (Vercel/K8s ingress)
AUTH_TRUST_HOST=true

# --- Supabase (server-side only; never exposed to the browser) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Anthropic (AI summarization / classification / executive summaries) ---
ANTHROPIC_API_KEY=

# --- Optional: secret for cron endpoints (Vercel Cron sends this as a Bearer token) ---
CRON_SECRET=

# --- TEMPORARY dev-only auth bypass (while Okta credentials are pending) ---
# Set ONLY in .env.local for local testing. The app hard-crashes at startup
# and at build time if this is set while NODE_ENV=production. Signs you in
# as DEV_BYPASS_EMAIL (default elliot.becker@wwt.com), which must still be
# an active roster member. Remove entirely once Okta is provisioned.
# DEV_BYPASS_AUTH=true
# DEV_BYPASS_EMAIL=elliot.becker@wwt.com
