# ============================================================================
# PROOF-OF-CONCEPT phase: only the two Supabase values below are required.
# Copy this file to .env.local and fill them in — then `npm run seed:dev`
# and `npm run dev` and you're testing.
# ============================================================================

# --- Supabase (server-side only; never exposed to the browser) — REQUIRED ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Anthropic — OPTIONAL (key still pending from IT) ---
# AI features (SPINA summaries, tier suggestions, weekly exec summary) show a
# clear "AI features unavailable" note until this is set. Everything else works.
ANTHROPIC_API_KEY=

# --- Auth mode ---
# "poc" (the default when unset): no-security name-picker login for the POC.
# "okta": real WWT SSO — requires the Okta + AUTH_SECRET values below.
# AUTH_MODE=poc

# ============================================================================
# Everything below is INACTIVE during the POC. It becomes required again when
# AUTH_MODE=okta (planned once Elena signs off on adding login security).
# ============================================================================

# --- Okta OIDC (SSO) ---
# Issuer is already provisioned for WWT SSO.
OKTA_ISSUER=https://sso.wwt.com/oauth2/default
OKTA_CLIENT_ID=
OKTA_CLIENT_SECRET=

# --- NextAuth ---
# Generate with: openssl rand -base64 32. Optional in POC mode (an insecure
# built-in fallback is used); REQUIRED in okta mode.
AUTH_SECRET=
# Set to the deployed URL in production (e.g. https://d2os-care.wwt.com)
AUTH_URL=http://localhost:3000
# Allow the app to trust the host header behind a proxy (Vercel/K8s ingress)
AUTH_TRUST_HOST=true

# --- Optional: secret for cron endpoints (Vercel Cron sends this as a Bearer token) ---
CRON_SECRET=

# --- TEMPORARY dev-only auth bypass (okta mode only; superseded by the POC
# name picker). Set ONLY in .env.local for local testing. The app hard-crashes
# at startup and at build time if this is set while NODE_ENV=production.
# Signs you in as DEV_BYPASS_EMAIL (default elliot.becker@wwt.com), which must
# still be an active roster member. Remove entirely once Okta is provisioned.
# DEV_BYPASS_AUTH=true
# DEV_BYPASS_EMAIL=elliot.becker@wwt.com
